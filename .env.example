APP_NAME=Agentic Career Search
DATABASE_URL=sqlite+aiosqlite:///./autoapply_agent.db
WORKER_POLL_INTERVAL_SECONDS=0.5
HTTP_TIMEOUT_SECONDS=12.0
MAX_JOBS_PER_SOURCE=50
HTTP_USER_AGENT=agentic-career-search/0.2
ENABLE_WORKER=true
LLM_ENABLE_ENRICHMENT=false
LLM_PROVIDER=gemini
LLM_TIMEOUT_SECONDS=12.0

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Kimi (Moonshot, OpenAI-compatible API)
KIMI_API_KEY=
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.moonshot.cn/v1

# Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-latest

# GPT (OpenAI-compatible API)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
